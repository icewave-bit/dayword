# FRONTEND (Vite): полный URL API, если запросы идут не с того же origin и без proxy
# Например https://api.example.com  (без хвостового слеша)
# Docker (браузер ходит на API с вашей машины, не из сети compose): например http://127.0.0.1:3001
# Один ingress (Traefik и т.п.) на один origin — можно оставить пустым и маршрутизировать /api на бэкенд.
VITE_API_URL=

# FRONTEND: при npm run dev — проксировать /api на бэкенд (при пустом VITE_API_URL)
# Явный target (если задан — он главный). Иначе: VITE_BACKEND_PROXY_HOST + API_PORT (по умолчанию 127.0.0.1:3001)
VITE_PROXY_API_TARGET=
# Хост бэкенда для dev-proxy. В Docker — имя сервиса, локально — 127.0.0.1
VITE_BACKEND_PROXY_HOST=127.0.0.1

# BACKEND (server/index.mjs): путь к SQLite после scripts/build_dictionary_sqlite.py
DICTIONARY_DB_PATH=./data/dictionary.db

# BACKEND: порт и хост HTTP API
API_PORT=3001
API_HOST=0.0.0.0

# BACKEND: CSV разрешённых Origin для CORS (пусто = reflect any в cors())
# Если фронт и API на разных origin (например web :8080 и API :3001), укажите origin фронта — иначе cookie-сессии не заработают.
# Пример для compose: http://localhost:8080
CORS_ORIGIN=

# BACKEND: лог /api/game/check + поле _debug в JSON. Вывод — в терминале, где запущен npm run dev:server
DEBUG_GAME_CHECK=

# FRONTEND (dev): console.info при проверке слова; в Network → /api/game/check смотрите _debug в JSON
VITE_DEBUG_CHECK=

# ADMIN: 32 байта в hex (64 символа) — ключ AES-256-GCM для шифрования логина/пароля в SQLite (admin_credentials)
# Первый админ: #/login → форма создания администратора; панель слов — #/admin после входа
ADMIN_ENCRYPTION_KEY=
# 1 — cookie с флагом Secure (HTTPS)
ADMIN_COOKIE_SECURE=

# Docker + Traefik (deploy only)
# hostname should match DNS for your reverse proxy.
APP_HOST=

# Traefik docker network name (`docker network ls`)
TRAEFIK_DOCKER_NETWORK=proxy
